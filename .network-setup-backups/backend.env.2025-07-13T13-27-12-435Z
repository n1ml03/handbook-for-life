# ============================================================================
# DOAXVV HANDBOOK BACKEND CONFIGURATION - DEVELOPMENT
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ============================================================================
# DATABASE CONFIGURATION (MySQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=doaxvv_handbook
DB_USER=root
DB_PASSWORD=namlepaylak

# Database Connection Pool Settings (Optimized for Development)
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=15000
DB_TIMEOUT=30000
DB_MAX_CONNECTION_ATTEMPTS=5
DB_CONNECTION_RETRY_DELAY=5000
DB_MONITORING_INTERVAL=60000
DB_ENABLE_QUERY_LOGGING=true

# Database SSL Configuration (Development - Disabled)
DB_SSL_REJECT_UNAUTHORIZED=false

# Database Timezone
DB_TIMEZONE=+00:00

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Local development origins and network access
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://172.20.10.5:3000,http://172.20.10.5:5173

# Network access origins (add your network IPs here)
# Example: http://192.168.1.100:3000,http://10.0.0.50:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://192.168.1.100:3000,http://192.168.1.100:5173

# Network configuration
# Server will bind to all interfaces (0.0.0.0) to accept network connections
# Change to 'localhost' or '127.0.0.1' to restrict to local access only
NETWORK_ACCESS_ENABLED=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_PREFIX=/api
API_VERSION=v1

# Rate Limiting (Disabled for Development)
ENABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Request Size Limits
MAX_REQUEST_SIZE=10mb
MAX_JSON_SIZE=1mb
MAX_URL_ENCODED_SIZE=1mb

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
JWT_SECRET=dev-jwt-secret-change-in-production-3a8f9c2e1d6b7a5e
SESSION_SECRET=dev-session-secret-change-in-production-8e4f2a9c1b6d3e7a
SESSION_MAX_AGE=86400000

# HTTPS Configuration (Development - Disabled)
FORCE_HTTPS=false
HSTS_MAX_AGE=31536000

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5mb
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,pdf,csv,json

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# ============================================================================
# MONITORING & HEALTH CHECK CONFIGURATION
# ============================================================================
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================
DETAILED_ERRORS=true
ENABLE_API_DOCS=true
ENABLE_REQUEST_LOGGING=true
ENABLE_HOT_RELOAD=true

# ============================================================================
# PRODUCTION OPTIMIZATIONS (Disabled for Development)
# ============================================================================
ENABLE_COMPRESSION=false
ENABLE_STATIC_CACHE=false
STATIC_CACHE_MAX_AGE=86400000
ENABLE_QUERY_OPTIMIZATION=false


# ============================================================================
# LOCALIZATION CONFIGURATION
# ============================================================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,jp,cn,tw,kr

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_GACHA_FEATURES=true
ENABLE_SHOP_FEATURES=true
ENABLE_UPDATE_LOGS=true
ENABLE_DOCUMENT_MANAGEMENT=true
ENABLE_ADMIN_FEATURES=true

# ============================================================================
# MIGRATION & SEEDING
# ============================================================================
AUTO_MIGRATE=false
AUTO_SEED=false
MIGRATION_LOCK_TIMEOUT=30000


# =============================================================================
# BUSINESS-FRIENDLY CONSOLE LOGGING
# =============================================================================

# Enable business-friendly mode for non-technical users
# When enabled, console output uses simple language and hides technical details
LOG_BUSINESS_MODE=false

# Hide technical metadata from console output
# Removes request IDs, technical parameters, and debugging information
LOG_HIDE_METADATA=true

# Hide stack traces from console output
# Prevents overwhelming non-technical users with code details
LOG_HIDE_STACK_TRACES=false

# Simplify technical messages to plain language
# Converts technical jargon to user-friendly descriptions
LOG_SIMPLIFY_MESSAGES=false


LOG_BUSINESS_FRIENDLY=false
LOG_HIDE_STACK_TRACES=true
LOG_HIDE_TECHNICAL_DETAILS=true
LOG_SIMPLIFY_MESSAGES=true
LOG_COMPACT_MODE=true
LOG_ENABLE_SEPARATORS=true